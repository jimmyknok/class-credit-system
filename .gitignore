# 依赖目录
node_modules/
.pnpm-store/          # 如果你以后切换到 pnpm

# 构建输出（Vite / React）
dist/
build/
.vite/                # Vite 缓存（极少见但有项目会生成）

# 日志和临时文件
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 环境变量（超级重要！别把密钥推上去）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# 编辑器 / IDE 配置文件
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# 系统生成的文件（尤其是 macOS 和 Windows）
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# 测试覆盖率报告（如果你以后加 jest/vitest）
coverage/
.nyc_output/

# 临时构建缓存
.cache/
.eslintcache
.stylelintcache

# Supabase 相关（如果你本地用了 Supabase CLI）
supabase/.branches/
supabase/migrations/*.sql.bak   # 偶尔会生成备份

# TypeScript 增量编译缓存
*.tsbuildinfo